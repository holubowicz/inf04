<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="Dodaj pracownika - 00000000000"
        Background="LightSteelBlue"
        Height="325" Width="700">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="SteelBlue" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="20" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="80" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0"
                  Grid.Column="0"
                  Header="Dane pracownika">
            <Grid Margin="20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="15" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="15" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Content="Imię" />
                <TextBox Grid.Row="0"
                         Grid.Column="2"
                         x:Name="FirstNameTextBox"
                         VerticalContentAlignment="Center" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Content="Nazwisko" />
                <TextBox Grid.Row="2"
                         Grid.Column="2"
                         x:Name="LastNameTextBox"
                         VerticalContentAlignment="Center" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Content="Stanowisko" />
                <ComboBox Grid.Row="4"
                          Grid.Column="2"
                          x:Name="PositionComboBox">
                    <ComboBoxItem Content="Kierownik" />
                    <ComboBoxItem Content="Starszy programista" />
                    <ComboBoxItem Content="Młodszy programista" />
                    <ComboBoxItem Content="Tester" />
                </ComboBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="0"
                  Grid.Column="2"
                  Header="Generowanie hasła">
            <StackPanel Margin="20,10">
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Content="Ile znaków?"
                           Margin="0,0,20,0" />

                    <TextBox Grid.Column="1"
                             x:Name="PasswordLengthTextBox"
                             VerticalContentAlignment="Center" />
                </Grid>

                <CheckBox x:Name="LowercaseAndUppercaseCheckBox"
                          Content="Małe i wielkie litery"
                          Margin="0,0,0,15"
                          IsChecked="True" />

                <CheckBox x:Name="DigitsCheckBox"
                          Content="Cyfry"
                          Margin="0,0,0,15" />

                <CheckBox x:Name="SpecialCharactersCheckBox"
                          Content="Znaki specjalne"
                          Margin="0,0,0,15" />

                <Button Content="Generuj hasło"
                        Click="GeneratePasswordButton_Click"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </GroupBox>

        <Button Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Content="Zatwierdź"
                Click="ConfirmButton_Click"
                Width="300"
                HorizontalAlignment="Center" />
    </Grid>

</Window>
