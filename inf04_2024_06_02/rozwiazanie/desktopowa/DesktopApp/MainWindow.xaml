<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="MojeDźwięki, Wykonał 00000000000" Height="350" Width="1200" Background="SeaGreen">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#61D918" />
            <Setter Property="FontSize" Value="20" />
        </Style>

        <Style x:Key="NavigationButton" TargetType="Button">
            <Setter Property="Height" Value="70" />
            <Setter Property="Margin" Value="20,0,30,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Style="{StaticResource NavigationButton}"
                Click="PreviousButton_Click">
            <Image Source="/Images/obraz3.png" />
        </Button>
        
        <StackPanel Grid.Column="1">
            <Grid Margin="0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/Images/obraz.png"
                       Height="220" Margin="0,0,25,0" />

                <StackPanel Grid.Column="1">
                    <Label x:Name="ArtistLabel"
                           Content="Artysta"
                           Foreground="White"
                           FontSize="50" />

                    <Label x:Name="AlbumLabel"
                           Content="Tytuł Albumu"
                           Foreground="White"
                           FontStyle="Italic"
                           FontSize="30" />

                    <StackPanel Orientation="Horizontal">
                        <Label x:Name="SongsNumberLabel"
                               Content="99 utworów"
                               Margin="0,0,30,0" />

                        <Label x:Name="YearLabel"
                               Content="2026" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                
                <Label Grid.Column="0"
                       x:Name="DownloadNumberLabel" 
                       Content="11000102" />

                <Button Grid.Column="1"
                        Content="Pobierz"
                        Click="DownloadButton_Click"
                        Padding="10,0"
                        Background="#61D918"
                        FontSize="20"
                        FontWeight="Bold" />
            </Grid>
        </StackPanel>

        <Button Grid.Column="2"
                Style="{StaticResource NavigationButton}"
                Click="NextButton_Click">
            <Image Source="/Images/obraz2.png" />
        </Button>
    </Grid>
    
</Window>
