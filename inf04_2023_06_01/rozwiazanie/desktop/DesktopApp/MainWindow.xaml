<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="Nadaj Przesyłkę, PESEL: 00000000000"
        Height="330" Width="700">

    <Grid Margin="30,20,30,0">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0"
                    Grid.Column="0">
            <StackPanel Width="220"
                        HorizontalAlignment="Left">
                <GroupBox Header="Rodzaj przesyłki">
                    <StackPanel Margin="5,10">
                        <RadioButton Content="Pocztówka"
                                     IsChecked="True" />

                        <RadioButton Content="List"
                                     x:Name="LetterRadioButton"
                                     Margin="0,10" />

                        <RadioButton Content="Paczka"
                                     x:Name="PackageRadioButton" />
                    </StackPanel>
                </GroupBox>

                <Button Content="Sprawdź Cenę"
                        Click="CheckPriceButton_Click"
                        Margin="0,10" />
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       x:Name="ShipmentTypeImage"
                       Source="/Images/pocztowka.png" />

                <Label Grid.Column="1"
                       x:Name="ShipmentPriceLabel"
                       Content="Cena: "
                       Margin="20,0,0,0"
                       FontSize="18"
                       FontWeight="Bold" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="0"
                    Grid.Column="1">
            <GroupBox Header="Dane adresowe">
                <StackPanel Margin="5,10">
                    <Label Content="Ulica z numerem" />
                    <TextBox Margin="0,0,0,5" />

                    <Label Content="Kod pocztowy" />
                    <TextBox x:Name="ZipCodeTextBox" Width="120"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,5" />

                    <Label Content="Miasto" />
                    <TextBox />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Button Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Content="Zatwierdź"
                Click="ConfirmButton_Click"
                Margin="0,5" />
    </Grid>

</Window>
