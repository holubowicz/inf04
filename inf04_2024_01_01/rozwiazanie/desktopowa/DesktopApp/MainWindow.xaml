<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="Wprowadzanie danych do paszportu. Wykonał 00000000000"
        Height="320" Width="750"
        Background="CadetBlue">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Azure" />
            <Setter Property="Margin" Value="0,5" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,3" />
        </Style>

        <Style TargetType="Image">
            <Setter Property="Height" Value="180" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="10" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Content="Numer" />

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         LostFocus="NumberTextBox_LostFocus" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Content="Imię" />

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         x:Name="FirstNameTextBox" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Content="Nazwisko" />

                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         x:Name="LastNameTextBox" />
            </Grid>

            <GroupBox Margin="0,30,0,0" Header="Kolor oczu">
                <StackPanel Margin="15,5">
                    <RadioButton Content="niebieskie"
                                 IsChecked="True"
                                 Checked="EyeColorRadioButton_Checked" />

                    <RadioButton Content="zielone"
                                 Checked="EyeColorRadioButton_Checked" />

                    <RadioButton Content="piwne"
                                 Checked="EyeColorRadioButton_Checked" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Column="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       x:Name="PersonImage"
                       Source="/Images/000-zdjecie.jpg" />

                <Image Grid.Column="1"
                       x:Name="FingerprintImage"
                       Source="/Images/000-odcisk.jpg" />
            </Grid>

            <Button Content="OK"
                    Click="OkButton_Click"
                    Margin="0,20,0,0"
                    Padding="120,10"
                    HorizontalAlignment="Center"
                    Background="Azure" />
        </StackPanel>
    </Grid>

</Window>
