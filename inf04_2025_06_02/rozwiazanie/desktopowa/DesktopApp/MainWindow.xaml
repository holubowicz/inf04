<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="Szyfrowanie. Wykonane przez 00000000000"
        Background="CadetBlue"
        Height="450" Width="750">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="AntiqueWhite" />
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5,15" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="30,0" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Background" Value="LightBlue" />
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Label Content="Podaj wartość klucza" />

            <TextBox x:Name="KeyTextBox"
                     Width="50" />

            <Label Content="Podaj tekst" />

            <TextBox x:Name="InputTextBox"
                     Height="250"
                     AcceptsReturn="True"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
            <Button Content="Zaszyfruj"
                    Click="EncryptButton_Click" />
        </StackPanel>

        <StackPanel Grid.Column="2">
            <Label Content="Tekst zaszyfrowany" />

            <Border Margin="0,20"
                    BorderBrush="AntiqueWhite"
                    BorderThickness="2"
                    CornerRadius="10">
                <TextBlock x:Name="ResultTextBlock"
                           Height="250"
                           Margin="15"
                           Foreground="AliceBlue" />
            </Border>

            <Button Content="Zapisz szyfr w pliku"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>

</Window>
