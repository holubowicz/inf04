<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="Wzornik kolorów RGB. Wykonał 00000000000"
        Background="Cornsilk"
        Height="350" Width="800">

    <Window.Resources>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="30,10">
        <Rectangle x:Name="ColorRectangle"
                   Height="60"
                   Margin="0,0,0,20"
                   Fill="White" />

        <Label Content="Dobierz kolor suwakami i zapisz przyciskiem:" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition />
                <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="R" />

            <Slider Grid.Column="1"
                    ValueChanged="RedColorSlider_ValueChanged"
                    Minimum="0"
                    Maximum="255"
                    Value="255" />

            <Label Grid.Column="2"
                   x:Name="RedColorLabel"
                   Content="255" />
        </Grid>

        <Grid Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition />
                <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="G" />

            <Slider Grid.Column="1"
                    ValueChanged="GreenColorSlider_ValueChanged"
                    Minimum="0"
                    Maximum="255"
                    Value="255" />

            <Label Grid.Column="2"
                   x:Name="GreenColorLabel"
                   Content="255" />
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition />
                <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="B" />

            <Slider Grid.Column="1"
                    ValueChanged="BlueColorSlider_ValueChanged"
                    Minimum="0"
                    Maximum="255"
                    Value="255" />

            <Label Grid.Column="2"
                   x:Name="BlueColorLabel"
                   Content="255" />
        </Grid>

        <Button Content="Pobierz"
                Click="SaveColorButton_Click"
                Width="180"
                Padding="0,5"
                Background="Peru" />

        <Label Content="255, 255, 255"
               x:Name="SaveColorLabel"
               Width="180"
               Margin="0,20,0,0"
               Background="White" />
    </StackPanel>
    
</Window>
